{
  "llm": {
    "baseUrl": "http://localhost:1234/v1",
    "apiKey": "lm-studio",
    "model": null
  },
  "server": {
    "host": "0.0.0.0",
    "port": 8000
  },
  "skills": {
    "dir": "~/.mtv-agent/skills",
    "maxActive": 3
  },
  "playbooks": {
    "dir": "~/.mtv-agent/playbooks"
  },
  "memory": {
    "maxTurns": 20,
    "ttlSeconds": 3600,
    "toolResultLimit": 4000
  },
  "agent": {
    "contextWindow": 30000,
    "maxIterations": 20,
    "maxRetries": 2,
    "retryDelay": 2.0,
    "llmTimeout": 360,
    "mcpToolTimeout": 360,
    "bashTimeout": 360
  },
  "cache": {
    "dir": "~/.mtv-agent/cache"
  }
}
